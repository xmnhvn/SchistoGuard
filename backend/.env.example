# Environment Configuration for SchistoGuard Backend

# Server
PORT=3001
NODE_ENV=development

# Database (choose one)
# For local development (SQLite):
DB_TYPE=sqlite
# For production (Postgres on Railway):
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@hostname:5432/schistoguard

# Session Secret (REQUIRED in production)
# Use at least 32 random characters. Example generation:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-very-long-random-session-secret-at-least-32-chars

# Protected default account (cannot be deleted, but password can be changed)
PROTECTED_ACCOUNT_EMAIL=admin@schistoguard.local
PROTECTED_ACCOUNT_PASSWORD=ChangeThis1!
PROTECTED_ACCOUNT_FIRST_NAME=SchistoGuard
PROTECTED_ACCOUNT_LAST_NAME=Admin
PROTECTED_ACCOUNT_ORGANIZATION=SchistoGuard

# Account registration policy
# false = only existing logged-in users can create new accounts (recommended)
# true = allow public signup via /api/auth/signup
ENABLE_SELF_SIGNUP=false

# Temporary admin unlock window (minutes) when a non-admin enters admin credentials
ADMIN_UNLOCK_MINUTES=10

# Per-account login lockout policy
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Frontend URL (for CORS, adjust for Vercel)
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://schistoguard.vercel.app

# Site Name (default)
SITE_NAME=Mang Jose's Fishpond

# ESP32 Bridge Configuration
# For cloud backend (Option A - recommended):
ESP32_BACKEND_URL=https://schistoguard-production.up.railway.app/api/sensors
# For local backend:
# ESP32_BACKEND_URL=http://localhost:3001/api/sensors

ESP32_HOSTNAME=schistoguard-esp32.local
ESP32_IP_FALLBACK=192.168.100.168
ESP32_POLL_INTERVAL=2000

# SMS Configuration
ENABLE_ESP32_SMS=true
ESP32_SMS_COOLDOWN_MS=300000

# Backend API Base URL (for frontend to know where to reach)
API_BASE_URL=http://localhost:3001
