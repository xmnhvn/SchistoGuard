# Environment Configuration for SchistoGuard Backend

# Server
PORT=3001
NODE_ENV=development

# Database (choose one)
# For local development (SQLite):
DB_TYPE=sqlite
# For production (Postgres on Railway):
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@hostname:5432/schistoguard

# Session Secret (change this for production!)
SESSION_SECRET=your-secure-secret-key-here-change-in-production

# Frontend URL (for CORS, adjust for Vercel)
FRONTEND_URL=http://localhost:5173

# Site Name (default)
SITE_NAME=Mang Jose's Fishpond

# ESP32 Bridge Configuration
# For cloud backend (Option A - recommended):
ESP32_BACKEND_URL=https://schistoguard-production.up.railway.app/api/sensors
# For local backend:
# ESP32_BACKEND_URL=http://localhost:3001/api/sensors

ESP32_HOSTNAME=schistoguard-esp32.local
ESP32_IP_FALLBACK=192.168.100.168
ESP32_POLL_INTERVAL=2000

# SMS Configuration
ENABLE_ESP32_SMS=true
ESP32_SMS_COOLDOWN_MS=300000

# Backend API Base URL (for frontend to know where to reach)
API_BASE_URL=http://localhost:3001
